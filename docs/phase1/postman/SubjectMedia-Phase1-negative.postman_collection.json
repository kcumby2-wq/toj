  "item": [
    {
      "name": "Campaigns",
      "item": [
        {
          "name": "Create campaign with negative budget",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/campaigns",
              "host": ["{{baseUrl}}"],
              "path": ["campaigns"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientOrgId\": \"bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb\",\n  \"name\": \"Invalid Budget Campaign\",\n  \"budgetAmount\": -10\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expected 400/422', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
