# CreatorLand Environment Configuration

# Email Configuration (Gmail)
# To set up automated email reports:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password (select "Mail" and "Windows Computer")
# 4. Copy the password and paste it below

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# Optional: Mailchimp sync for captured subscribers
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_LIST_ID=your-mailchimp-audience-id

# Report Settings
# Set to 'false' to disable automatic report generation
REPORTS_ENABLED=true

# Server Configuration
PORT=3000
SESSION_SECRET=your-secret-key-change-in-production

# Base URL (for links in emails)
BASE_URL=http://localhost:3000

# PostgreSQL (Phase 1 SQL workflow)
# Used by npm scripts: db:schema, db:seed, db:smoke, db:reset
# db:reset also reads this value from local .env when env var is not exported.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/subjectmedia

# Stripe Configuration (for payment processing)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLIC_KEY=pk_test_your_key_here
